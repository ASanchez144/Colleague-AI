# ============================================================
#  Tu Socia! — Variables del orquestador Claude (via Ollama)
#  Ruta destino: /etc/tusocia/orchestrator.env  (modo 0640, root:root)
# ============================================================
#
# Estas son las variables que el binario `claude` (Claude Code) espera cuando
# Ollama actúa como proxy local. Documentadas en:
#   https://docs.ollama.com/integrations/claude-code
#
# No pongas aquí ningún secreto real de Anthropic: con Ollama no hace falta.
#
ANTHROPIC_AUTH_TOKEN=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=http://127.0.0.1:11434

# Modelo por defecto que usa Claude Code vía Ollama.
# Tiene que existir exactamente con este nombre en `ollama list`.
# Ejemplos válidos: "gemma4:cloud", "kimi-k2.5:cloud", "glm-5:cloud", "qwen3.5".
CLAUDE_MODEL=gemma4:31b-cloud

# Directorio raíz del proyecto (el bootstrap lo ajusta al clonar).
TUSOCIA_HOME=/root/tusocia

# Ventana de contexto mínima que Claude Code pide (64k).
CLAUDE_MIN_CTX=65536

# Timeout de llamadas al modelo (Claude Code las corta a 60s por defecto).
API_TIMEOUT_MS=600000
