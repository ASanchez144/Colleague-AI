# ============================
# Tu Socia! - Server Config
# ============================

# Puerto del servidor Express
PORT=3001

# Resend API Key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email remitente (debe estar verificado en Resend)
FROM_EMAIL=hola@tusocia.es

# Email del admin para notificaciones
ADMIN_EMAIL=arturoeldeteruel@gmail.com

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Webhook secret (cualquier string secreto que tú elijas)
WEBHOOK_SECRET=test-secret-local

# Clave de acceso a endpoints admin (/api/leads, /api/jobs)
# Generar con: openssl rand -hex 32
ADMIN_API_KEY=cambia-esto-por-un-hash-seguro

# Directorio base de templates
TEMPLATES_DIR=../templates

# Directorio de clientes generados
CLIENTS_DIR=../clients

# Log level: error, warn, info, debug
LOG_LEVEL=debug

# ─── EvolutionAPI (WhatsApp) ───────────────────────────────────────────────────
# URL donde corre EvolutionAPI (Docker local → 8080)
EVOLUTION_API_URL=http://localhost:8080

# Clave maestra de EvolutionAPI — debe coincidir con AUTHENTICATION_API_KEY en docker-compose.yml
EVOLUTION_API_KEY=tusocia-secret-key

# Nombre de la instancia que crearás dentro de EvolutionAPI (puedes dejarlo así)
EVOLUTION_INSTANCE_NAME=tu-socia

# URL pública donde EvolutionAPI enviará los callbacks de mensajes
# En desarrollo: tu URL de ngrok  (ej: https://a1b2c3d4.ngrok-free.app/webhook/whatsapp)
# En producción: https://tusocia.es/webhook/whatsapp
WEBHOOK_CALLBACK_URL=https://TU_URL_NGROK/webhook/whatsapp

# Puerto del servidor de WhatsApp (separado del servidor principal en 3001)
WHATSAPP_PORT=3002

# ─── Configuración del Bot ────────────────────────────────────────────────────
COMPANY_NAME=Tu Socia!
WELCOME_MESSAGE=¡Hola! Soy la asistente virtual de {{company}}. ¿En qué puedo ayudarte hoy?
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=20:00
BUSINESS_HOURS_TIMEZONE=Europe/Madrid
OUT_OF_HOURS_MESSAGE=Gracias por escribirnos. Nuestro horario es de 9:00 a 20:00. Te responderemos a primera hora.
